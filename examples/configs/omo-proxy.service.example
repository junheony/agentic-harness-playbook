# systemd user unit — omo_proxy (opencode → Claude OAuth proxy)
# 위치: ~/.config/systemd/user/omo-proxy.service
#
# ⚠️ Off-policy 영역: Claude Code의 OAuth 토큰을 opencode 같은 3rd-party 도구에서
# 재사용하는 패턴. Anthropic ToS (2026-04 발효)에서 명시적으로 금지됨.
# 본인 계정 / 본인 책임 하에만 사용. README의 OAuth 정책 섹션 참고.
#
# 사전 준비:
#   1. Claude Code 데스크탑에서 정상 로그인된 호스트의
#      ~/.claude/.credentials.json (chmod 600)를 서버로 옮김
#      (예: scp -p ~/.claude/.credentials.json server:~/.claude/.credentials.json)
#   2. git clone https://github.com/winglock/omo_proxy ~/omo_proxy
#   3. node 18+ 설치 (proxy.js는 built-in 모듈만 사용)
#   4. loginctl enable-linger $USER (부팅 시 자동 시작)
#
# 활성화:
#   systemctl --user daemon-reload
#   systemctl --user enable --now omo-proxy.service
#
# 검증:
#   ss -tlnp | grep 34156       # listen 확인
#   tail -f ~/omo_proxy/proxy.log
#   curl -fs http://127.0.0.1:34156/  # 404 = 정상 (path-based routing)
#
# opencode 연결:
#   ~/.config/opencode/opencode.json:
#     {
#       "provider": {
#         "anthropic": {
#           "options": {
#             "baseURL": "http://127.0.0.1:34156/v1",
#             "apiKey": "proxy-placeholder"
#           }
#         }
#       }
#     }

[Unit]
Description=omo_proxy - OpenCode <-> Claude OAuth proxy (prompt-cache preserving)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/home/YOUR_USERNAME/omo_proxy
ExecStart=/usr/bin/node /home/YOUR_USERNAME/omo_proxy/proxy.js

Restart=on-failure
RestartSec=10

StandardOutput=append:/home/YOUR_USERNAME/omo_proxy/proxy.log
StandardError=append:/home/YOUR_USERNAME/omo_proxy/proxy.err.log

Environment=NODE_ENV=production

[Install]
WantedBy=default.target
