#!/usr/bin/env bash
# Quant daily ingest (06:00 KST).
# TODO: 실제 market data fetch 로직은 agent가 작업할 때 채움.
# 지금은 placeholder — routine 시스템만 검증.
set -uo pipefail

TODAY=$(date +%Y-%m-%d)
OUTDIR=~/dashboard-output/quant-cycles/$TODAY
mkdir -p "$OUTDIR"

echo "$(date -u +%Y-%m-%dT%H:%M:%SZ) ingest started" > "$OUTDIR/ingest.log"
echo "TODO: implement market data fetch" >> "$OUTDIR/ingest.log"
echo "status: placeholder" >> "$OUTDIR/ingest.log"

# meta.json (state machine)
cat > "$OUTDIR/meta.json" <<EOF
{
  "cycle_date": "$TODAY",
  "status": "draft",
  "ingest_at": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "stage": "ingest",
  "note": "placeholder — agent에게 ingest 로직 위임 필요"
}
EOF

echo "$(date -u +%Y-%m-%dT%H:%M:%SZ) ingest done"
