# mini-router 환경변수 — ~/.hermes/.env 로 복사 후 값 채우기 (chmod 600)
#
# 주의: systemd EnvironmentFile은 $HOME 같은 변수를 확장하지 않습니다.
#       bot.py가 $HOME / ~ 를 자체적으로 확장해 주긴 하지만,
#       혼동을 줄이려면 아래처럼 절대 경로를 그대로 쓰는 것을 권장합니다.

# 봇 토큰 — 가능하면 여기 대신 secret-tool(Linux) / Keychain(macOS)에 저장 (README 참고).
# 파일에 직접 쓸 경우에만 주석 해제:
# TELEGRAM_BOT_TOKEN=<bot-token>

# 필수: 허용 user_id 화이트리스트 (콤마구분). 미설정 시 봇이 기동을 거부함.
TELEGRAM_ALLOWED_USERS=<your-numeric-user-id>

# 선택: 허용 chat_id 화이트리스트 (콤마구분). supergroup은 -100 prefix.
# 설정하면 user 화이트리스트에 더해 채팅방까지 제한 (권장).
TELEGRAM_ALLOWED_CHATS=<supergroup-chat-id-with--100-prefix>

# 기본 작업 디렉토리
WORKDIR_ROOT=/home/YOUR_USERNAME/dev

# 기본 forwarding 대상 tmux 세션
TMUX_DEFAULT_SESSION=oc-default

# 토픽 매핑 yaml (선택) — examples/configs/topic-map.example.yaml 참고
TOPIC_MAP_PATH=/home/YOUR_USERNAME/.hermes/topic_map.yaml

# 선택: oc-*/cc-* 가 아닌 tmux 세션으로도 forwarding 허용.
# 기본은 차단 — Telegram이 raw shell 원격 채널이 되는 것을 막는 안전 가드.
# ALLOW_RAW_SHELL_SESSIONS=1

# 선택: 세션 cold start 시 CLI 부팅 대기 초 (default: 3)
# BOOT_WAIT_SECS=3

# (reserved) v1 bot.py는 읽지 않음 — v2 결과 push(tmux pipe-pane) 용으로 예약.
# TELEGRAM_OPS_CHAT_ID=<ops-chat-id>
